# Private leak inventory + adversarial test fixtures live here. Never committed.
.local/

# Local private-token denylist read by gate-gh-public-actions.sh. Never committed;
# only config/private-tokens.example.txt ships as a template.
config/private-tokens.txt

# Runtime knowledge-base content populated by strata-init lives inside the
# install tree by default; never check that into the public repo. Override
# $KB_DIR to point this elsewhere before running strata-init when you want
# to bypass these ignore rules.
workspace/areas/
workspace/projects/
workspace/resources/
workspace/daily/
workspace/inbox/
workspace/archives/
workspace/state/
workspace/tacit.md
strata.env

# OS + editor noise
.DS_Store
*.swp
*~

# Python / node noise that may appear if users extend strata
__pycache__/
*.pyc
node_modules/
.venv/

# Rust build artifacts (the cli/ crate) — never belong in the repo
target/
cli/target/

# This repo's own dev scratch (build-time specs, verify markers, local settings).
# Not part of the shipped skeleton; kept out of the public tree.
.claude/

# Runtime state never belongs in the install tree; workspace/ has its own state dirs
*.log
*.pid

# Stop hook markers + session edit lists (created at runtime under workspace/, but globbed for safety)
.session-edits-*
.verify-passed-*
*.out

# Telemetry runtime artifacts. The telemetry/ SCRIPTS + model_rates.json template ship; live
# event/metric data does NOT. Default runtime sink is $STATE_DIR/telemetry (under workspace/state/,
# already ignored above); these patterns are belt-and-suspenders if telemetry writes elsewhere.
telemetry/events.jsonl
telemetry/session-metrics.jsonl
telemetry/telemetry-errors.jsonl
telemetry/*-health.jsonl
telemetry/archive/
telemetry/*.lock
.rotate.lock
