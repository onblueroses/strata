#!/usr/bin/env bash
# Session stop hook - blocks session end until verification passes.
# Disable enforcement: set `enforce = false` under [hooks] in strata.toml.

set -euo pipefail

STRATA_DIR=".strata"
MARKER="$STRATA_DIR/.verify-passed"

echo "Session stopped: $(date -u +%Y-%m-%dT%H:%M:%SZ)"

# Check for uncommitted changes
if command -v git &>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null; then
    changes=$(git status --porcelain 2>/dev/null || true)
    if [ -n "$changes" ]; then
        changed_count=$(echo "$changes" | wc -l | tr -d ' ')
        echo ""
        echo "WARNING: $changed_count uncommitted file(s) detected."
        echo "Run /review and commit before ending the session."
        echo ""
        echo "Changed files:"
        echo "$changes" | head -20
        if [ "$changed_count" -gt 20 ]; then
            echo "  ... and $((changed_count - 20)) more"
        fi
    fi
fi

# Enforcement gate: verify must have passed
{% if enforce %}
if [ ! -f "$MARKER" ]; then
    echo ""
    echo "BLOCKED: Verification has not passed this session."
    echo "Run /verify before ending the session."
    echo ""
    echo "To disable enforcement, set enforce = false under [hooks] in strata.toml."
    exit 1
fi
echo "Verification: passed (marker found)"
{% else %}
# Enforcement disabled - warn only
if [ ! -f "$MARKER" ]; then
    echo ""
    echo "NOTE: Verification has not run this session. Consider running /verify."
fi
{% endif %}

# Log to sessions directory if it exists
SESSIONS_DIR="$STRATA_DIR/sessions"
if [ -d "$SESSIONS_DIR" ]; then
    echo "$(date +%s | sha256sum 2>/dev/null | head -c 8 || echo 'unknown') $(date -u +%Y-%m-%dT%H:%M:%SZ) stop" >> "$SESSIONS_DIR/session-log.txt"
fi
